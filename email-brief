#!/bin/zsh
# Email triage tool. Substitutes today's dates into the prompt template and
# runs it through `claude -p`. Pipe-form stdin avoids arg-length/quoting limits
# on the long prompt. Tools are pinned so unattended (launchd) runs never block
# on a permission prompt; model is pinned for reproducible cost/latency.
TODAY=$(date +%Y-%m-%d)
YESTERDAY=$(date -v-1d +%Y-%m-%d)

PROMPT=$(sed "s/{{date}}/$TODAY/g; s/{{yesterday}}/$YESTERDAY/g" ~/.claude/email-brief-prompt.md)

echo "$PROMPT" | claude -p --allowedTools "Bash,Read,Write" --model claude-sonnet-4-6

# Desktop notification so a manual or scheduled run announces completion.
osascript -e "display notification \"Email briefing ready: ~/morning-brief/$TODAY-email.md\" with title \"Email Debriefing\" sound name \"Glass\""
