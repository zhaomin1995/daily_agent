#!/bin/zsh
TODAY=$(date +%Y-%m-%d)
YESTERDAY=$(date -v-1d +%Y-%m-%d)
PROMPT=$(sed "s/{{date}}/$TODAY/g; s/{{yesterday}}/$YESTERDAY/g" ~/.claude/workflow-brief-prompt.md)
claude -p "$PROMPT" --allowedTools "Bash,Read,Write" --model claude-sonnet-4-6
osascript -e "display notification \"Workflow summary ready. Check ~/morning-brief/$TODAY-workflow.md\" with title \"Workflow Summary\" sound name \"Glass\""
